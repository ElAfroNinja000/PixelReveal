{
  "name": "pixelreveal",
  "version": "0.0.0",
  "private": true,
  "description": "Canvas pixel art collaboratif temps réel sur Cloudflare Workers + Durable Objects",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787 --local --var ENVIRONMENT:dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "smoke": "node tools/smoke-ws.mjs",
    "smoke:reprise": "node tools/smoke-reprise.mjs",
    "reset": "node -e \"require('fs').rmSync('.wrangler/state',{recursive:true,force:true})\"",
    "pages:deploy": "wrangler pages deploy ./public"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240605.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.4.5",
    "wrangler": "^3.60.0",
    "ws": "^8.21.0"
  }
}
